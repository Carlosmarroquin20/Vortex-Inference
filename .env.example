# Local development overrides for the Vortex inference server.
# Copy to .env and adjust for your local setup.
# NEVER commit .env to version control — it may contain sensitive paths or tokens.
#
# In Kubernetes, these values are injected via the ConfigMap in k8s/configmap.yaml.
# The VORTEX_ prefix is defined in app/config.py via env_prefix="VORTEX_".

# Path to the GGUF model file on the local filesystem (not inside Minikube).
# For local development outside Kubernetes, point this at the downloaded model.
VORTEX_MODEL_PATH=./models/phi-3-mini-4k-instruct-q4_k_m.gguf
VORTEX_MODEL_NAME=phi-3-mini-4k-instruct

# Context window size. Must not exceed the model's training context (4096 for Phi-3-mini).
VORTEX_N_CTX=4096

# Match to the number of physical CPU cores available to the process.
# On a developer laptop, 4 is a reasonable value that leaves headroom for the IDE.
VORTEX_N_THREADS=4

# 0 = CPU-only inference. No GPU required for local development.
VORTEX_N_GPU_LAYERS=0

# 1 = serialized inference per process. Horizontal scaling is handled by KEDA.
VORTEX_MAX_CONCURRENT_REQUESTS=1

VORTEX_PORT=8080
VORTEX_INFERENCE_TIMEOUT_SECONDS=120.0
